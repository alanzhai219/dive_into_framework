        <mxCell id="sU8PSUKhDcx1YNUkFXAb-86" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="scale_j = d × (scales[j] &amp;amp; 0xF)&lt;br&gt;min_j = dmin x (scales[j] &amp;gt;&amp;gt; 4)&lt;br&gt;&lt;br&gt;L[i] = round((x[i] + min_j) / scale_j)&lt;br&gt;L ∈ [0, 3]&amp;nbsp; --- 2-bit&amp;nbsp;" vertex="1">
          <mxGeometry height="80" width="200" x="1280" y="240" as="geometry" />
        </mxCell>
