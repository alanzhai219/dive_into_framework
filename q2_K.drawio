        <mxCell id="sU8PSUKhDcx1YNUkFXAb-156" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;   mem addr:     structure                       size       description&lt;br&gt;   ┌──────────────────────────────────────────────────────────────────────┐&lt;br&gt;   │ +0x00      scales[0]  = min₀&amp;lt;&amp;lt;4  | scale₀   1 byte                   │&lt;br&gt;   │ +0x01      scales[1]  = min₁&amp;lt;&amp;lt;4  | scale₁   1 byte                   │&lt;br&gt;   │ +0x02      scales[2]  = min₂&amp;lt;&amp;lt;4  | scale₂   1 byte                   │&lt;br&gt;   │ ...                                                                  │&lt;br&gt;   │ +0x0F      scales[15] = min₁₅&amp;lt;&amp;lt;4 | scale₁₅  1 byte                   │&lt;br&gt;   ├──────────────────────────────────────────────────────────────────────┤&lt;br&gt;   │ +0x10      qs[0]                            1 byte                   │&lt;br&gt;   │ +0x11      qs[1]                            1 byte                   │&lt;br&gt;   │ ...                                                                  │&lt;br&gt;   │ +0x4F      qs[63]                           1 byte                   │&lt;br&gt;   ├──────────────────────────────────────────────────────────────────────┤&lt;br&gt;   │ +0x50      d          (super-block scale)   2 bytes (float16)        │&lt;br&gt;   │ +0x52      dmin       (super-block min)     2 bytes (float16)        │&lt;br&gt;   └──────────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="60" width="160" x="2550" y="260" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-157" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;   ┌───────────────────────────────────────────────────────┐&lt;br&gt;   │ Sub-block 0 : L[0],   L[1],   L[2],   ..., L[15]      │&lt;br&gt;   │ Sub-block 1 : L[16],  L[17],  L[18],  ..., L[31],     │&lt;br&gt;   │ Sub-block 2 : L[32],  L[33],  L[34],  ..., L[47],     │&lt;br&gt;   | ...         : ...                                     │&lt;br&gt;   │ Sub-block 15: L[240], L[241], L[242], ..., L[255]     │&lt;br&gt;   └───────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="125" width="400" x="1760" y="760" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-159" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; text-align: start; background-color: rgb(37, 37, 38); font-size: 13px; color: rgb(204, 204, 204);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;        ┌─────────┬─────────┬─────────┬─────────┐&lt;br&gt;        │ bit 7-6 │ bit 5-4 │ bit 3-2 │ bit 1-0 │&lt;br&gt;        │ (SB 3)  │ (SB 2)  │ (SB 1)  │ (SB 0)  │&lt;br&gt;        └─────────┴─────────┴─────────┴─────────┘&lt;br&gt;        ┌─────────┬─────────┬─────────┬─────────┐&lt;br&gt;qs[0]   │ L[96]   │ L[64]   │ L[32]   │ L[0]    │&lt;br&gt;        ├─────────┼─────────┼─────────┼─────────┤&lt;br&gt;qs[1]   │ L[97]   │ L[65]   │ L[33]   │ L[1]    │&lt;br&gt;        ├─────────┼─────────┼─────────┼─────────┤&lt;br&gt;qs[..]  │ L[..]   │ L[..]   │ L[..]   │ L[..]   │&lt;br&gt;        ├─────────┼─────────┼─────────┼─────────┤&lt;br&gt;qs[31]  │ L[127]  │ L[95]   │ L[63]   │ L[31]   │&lt;br&gt;        └─────────┴─────────┴─────────┴─────────┘&lt;br&gt;        ┌─────────┬─────────┬─────────┬─────────┐&lt;br&gt;qs[32]  │ L[224]  │ L[192]  │ L[160]  │ L[128]  │&lt;br&gt;        ├─────────┼─────────┼─────────┼─────────┤&lt;br&gt;qs[33]  │ L[225]  │ L[193]  │ L[161]  │ L[129]  │&lt;br&gt;        ├─────────┼─────────┼─────────┼─────────┤&lt;br&gt;qs[..]  │ L[..]   │ L[..]   │ L[..]   │ L[..]   │&lt;br&gt;        ├─────────┼─────────┼─────────┼─────────┤&lt;br&gt;qs[63]  │ L[255]  │ L[223]  │ L[191]  │ L[159]  │&lt;br&gt;        └─────────┴─────────┴─────────┴─────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="360" width="330" x="1760" y="920" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-162" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;mem addr: 0x0000          0x0040          0x0080          0x00C0     ...       0x03C0&lt;br&gt;           │               │               │               │                    │&lt;br&gt;           ▼               ▼               ▼               ▼                    ▼&lt;br&gt;   ┌───────────────┬───────────────┬───────────────┬───────────────┬─────┬───────────────┐&lt;br&gt;   │  Sub-block 0  │  Sub-block 1  │  Sub-block 2  │  Sub-block 3  │ ... │  Sub-block 15 │&lt;br&gt;   │   x[0..15]    │  x[16..31]    │  x[32..47]    │  x[48..63]    │     │ x[240..255]   │&lt;br&gt;   │   16 floats   │   16 floats   │   16 floats   │   16 floats   │     │   16 floats   │&lt;br&gt;   │   64 bytes    │   64 bytes    │   64 bytes    │   64 bytes    │     │   64 bytes    │&lt;br&gt;   └───────────────┴───────────────┴───────────────┴───────────────┴─────┴───────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="150" width="590" x="40" y="560" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-163" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;┌──────────────────────────────────────────────────────────────────────────┐&lt;br&gt;│ scales[16]:  [s₀, s₁, s₂, ..., s₁₅]     16 × float32 = 64 bytes          │&lt;br&gt;│ mins[16]:    [m₀, m₁, m₂, ..., m₁₅]     16 × float32 = 64 bytes          │&lt;br&gt;│ L[256]:      [q₀, q₁, q₂, ..., q₂₅₅]    256 × uint8 = 256 bytes          │&lt;br&gt;└──────────────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="90" width="500" x="40" y="800" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-164" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px;&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;super-block:&lt;br&gt;┌─────────────────────────────────────────┐&lt;br&gt;│  max_scale = max(scales[0..15])         │&lt;br&gt;│  max_min   = max(mins[0..15])           │&lt;br&gt;└─────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="110" width="310" x="40" y="920" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-165" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;quantize scale:&lt;br&gt;┌────────────────────────────────────────────────────────────────┐&lt;br&gt;│  d = max_scale / 15.0                  ← Super-block scale     │&lt;br&gt;│                                                                │&lt;br&gt;│  for j = 0..15:                                                │&lt;br&gt;│    q_scale[j] = round(scales[j] * 15.0 / max_scale)            │&lt;br&gt;│    q_scale[j] ∈ [0, 15]  (4-bit)                               │&lt;br&gt;└────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="140" width="440" x="680" y="760" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-166" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;quantize min:&lt;br&gt;┌────────────────────────────────────────────────────────────────┐&lt;br&gt;│  dmin = max_min / 15.0                 ← Super-block min scale │&lt;br&gt;│                                                                │&lt;br&gt;│  for j = 0..15:                                                │&lt;br&gt;│    q_min[j] = round(mins[j] * 15.0 / max_min)                  │&lt;br&gt;│    q_min[j] ∈ [0, 15]  (4-bit)                                 │&lt;br&gt;└────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="140" width="440" x="680" y="920" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-167" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;pack q_scale and q_min to scales(one byte):&lt;br&gt;┌────────────────────────────────────────────────────────────────┐&lt;br&gt;│  y[i].scales[j] = (q_min[j] &amp;lt;&amp;lt; 4) | q_scale[j]                 │&lt;br&gt;│                                                                │&lt;br&gt;│  Bit layout:  [7 6 5 4 | 3 2 1 0]                              │&lt;br&gt;│               └─ min ─┘ └ scale ┘                              │&lt;br&gt;└────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="127.5" width="440" x="680" y="1082.5" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-169" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;memory status:&lt;br&gt;┌──────────────────────────────────────────────────────────────────┐&lt;br&gt;│ y[i].scales[16]:  16 × uint8 = 16 bytes                          │&lt;br&gt;│                   ┌──┬──┬──┬──┬─────┬───┐                        │&lt;br&gt;│                   │s₀│s₁│s₂│s₃│ ... │s₁₅│                        │&lt;br&gt;│                   └──┴──┴──┴──┴─────┴───┘                        │&lt;br&gt;│                                                                  │&lt;br&gt;│ y[i].d:      1 × float16 = 2 bytes  (max_scale/15)               │&lt;br&gt;│ y[i].dmin:   1 × float16 = 2 bytes  (max_min/15)                 │&lt;br&gt;└──────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="170" width="450" x="680" y="1240" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-170" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;for each Sub-block j:&lt;br&gt;┌────────────────────────────────────────────────────────────────────────┐&lt;br&gt;│  1. restore scale and min:                                             │&lt;br&gt;│     scale_j = d × (scales[j] &amp;amp; 0xF)                                    │&lt;br&gt;│     min_j   = dmin × (scales[j] &amp;gt;&amp;gt; 4)                                  │&lt;br&gt;│                                                                        │&lt;br&gt;│  2. quantize U8 to 2-bit:                                              │&lt;br&gt;│     for ii = 0..15:                                                    │&lt;br&gt;│       L[16*j + ii] = clamp(round((x[16*j+ii] + min_j) / scale_j), 0, 3)│&lt;br&gt;│                      └─────────────┬─────────────┘                     │&lt;br&gt;│                           quantize to [0,3]                            │&lt;br&gt;└────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="200" width="490" x="1160" y="760" as="geometry" />
        </mxCell>
        <mxCell id="sU8PSUKhDcx1YNUkFXAb-171" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;memory status (temp):&lt;br&gt;┌──────────────────────────────────────────────────────────────────┐&lt;br&gt;│ L[256]:  each value ∈ {0, 1, 2, 3}  (2-bit, but store as uint8)  │&lt;br&gt;│          256 × uint8 = 256 bytes                                 │&lt;br&gt;└──────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="90" width="450" x="1160" y="1000" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
