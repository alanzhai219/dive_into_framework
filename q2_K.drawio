        <mxCell id="sU8PSUKhDcx1YNUkFXAb-156" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin: 0px; padding: 8px; color: rgb(204, 204, 204); font-size: 13px; text-align: start; background-color: rgb(37, 37, 38);&quot;&gt;&lt;code style=&quot;color: rgb(215, 186, 125); background-color: rgba(255, 255, 255, 0.1); padding: 0px; border-radius: 3px; word-break: break-word; font-size: 0.9em;&quot;&gt;   mem addr:     structure                       size       description&lt;br&gt;   ┌──────────────────────────────────────────────────────────────────────┐&lt;br&gt;   │ +0x00      scales[0]  = min₀&amp;lt;&amp;lt;4  | scale₀   1 byte                   │&lt;br&gt;   │ +0x01      scales[1]  = min₁&amp;lt;&amp;lt;4  | scale₁   1 byte                   │&lt;br&gt;   │ +0x02      scales[2]  = min₂&amp;lt;&amp;lt;4  | scale₂   1 byte                   │&lt;br&gt;   │ ...                                                                  │&lt;br&gt;   │ +0x0F      scales[15] = min₁₅&amp;lt;&amp;lt;4 | scale₁₅  1 byte                   │&lt;br&gt;   ├──────────────────────────────────────────────────────────────────────┤&lt;br&gt;   │ +0x10      qs[0]                            1 byte                   │&lt;br&gt;   │ +0x11      qs[1]                            1 byte                   │&lt;br&gt;   │ ...                                                                  │&lt;br&gt;   │ +0x4F      qs[63]                           1 byte                   │&lt;br&gt;   ├──────────────────────────────────────────────────────────────────────┤&lt;br&gt;   │ +0x50      d          (super-block scale)   2 bytes (float16)        │&lt;br&gt;   │ +0x52      dmin       (super-block min)     2 bytes (float16)        │&lt;br&gt;   └──────────────────────────────────────────────────────────────────────┘&lt;/code&gt;&lt;/pre&gt;" vertex="1">
          <mxGeometry height="60" width="160" x="2550" y="260" as="geometry" />
