        <mxCell id="sU8PSUKhDcx1YNUkFXAb-83" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="0-quantize" vertex="1">
